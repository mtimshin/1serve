# Nuxt Studio Environment Variables

# GitHub Token (Optional for public, required for writing to private repos or saving commits from UI)
# Получите токен на https://github.com/settings/tokens
STUDIO_GITHUB_TOKEN=your_github_token_here

# GitLab Token (If using GitLab)
# STUDIO_GITLAB_TOKEN=your_gitlab_token_here

# Git Provider (github, gitlab, etc.)
NUXT_STUDIO_GIT_PROVIDER=github
